# Environment Configuration
# Copy this file to .env and fill in your actual values, OR let `azd up`
# generate it for you from the provisioned infrastructure outputs.

# Microsoft Foundry project endpoint.
# azd writes this automatically after provisioning (bicep output PROJECT_ENDPOINT).
# You can also copy it from the Foundry portal project overview page.
PROJECT_ENDPOINT=your_project_endpoint_here

# Name of the agent created by scripts/setup (or created manually in the portal).
AGENT_NAME=it-support-agent

# Model deployment name used when the agent is created (must match the bicep deployment).
MODEL_DEPLOYMENT_NAME=gpt-4o
